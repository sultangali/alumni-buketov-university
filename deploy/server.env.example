# Backend environment.
# Copy to  server/.env  (deploy.sh creates it automatically on first run with a
# freshly generated JWT_SECRET). Keep this file secret: chmod 600.

PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/alumni

# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

NODE_ENV=production
